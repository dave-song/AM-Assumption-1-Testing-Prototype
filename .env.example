# Moderator / researcher access keys (REQUIRED for /admin and facilitator panel)
ADMIN_KEY=change-me-admin
FACILITATOR_KEY=change-me-facilitator

# --- Persistence ------------------------------------------------------------
# LOCAL (single laptop): leave Supabase unset. The app uses a local JSON file
# store (.data/sessions.json) plus the browser's localStorage. Simple, no setup.
#
# HOSTED (Vercel / remote participants): Supabase is REQUIRED. Vercel's
# filesystem is ephemeral, so the file store does NOT persist there — without
# Supabase you will silently lose every remote participant's data. Set both:
#   SUPABASE_URL          = https://<project-ref>.supabase.co
#   SUPABASE_SERVICE_KEY  = the service_role key (Project Settings → API).
# Keep the service key server-only — do NOT prefix it with NEXT_PUBLIC.
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# (SUPABASE_ANON_KEY also works but needs row-level-security policies; the
#  service_role key bypasses RLS and is simpler for this server-only use.)

# Exposed to the client so the facilitator panel knows whether a key is required.
NEXT_PUBLIC_FACILITATOR_REQUIRED=true
